# =====================================================================
# TenderMind AI — backend environment (committed for hackathon evaluators)
# This file is intentionally checked in so the project runs with zero
# config edits. For real deployments, rotate JWT_SECRET and override any
# host-specific values via a local .env.override (gitignored).
# All paths are absolute or relative to the backend/ working directory.
# =====================================================================

# --- App ---
APP_ENV=dev
APP_PORT=8000
FRONTEND_ORIGIN=http://localhost:3000

# --- Storage (kept on D drive, in-project) ---
STORAGE_ROOT=D:/AI4Bharat/storage
SIGNING_KEY_PATH=D:/AI4Bharat/storage/keys/report_signing.pem
CHROMA_PATH=D:/AI4Bharat/storage/chroma

# --- Auth ---
# Demo secret committed for hackathon evaluators. ROTATE before real use.
# Regenerate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=tendermind-demo-secret-change-me-before-production
JWT_ALG=HS256
JWT_EXPIRE_MIN=480

# --- Postgres (native Windows install) ---
POSTGRES_DSN=postgresql+psycopg2://tendermind:tendermind@localhost:5432/tendermind

# --- MongoDB (native Windows install) ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB=tendermind

# --- Redis (Celery broker) ---
REDIS_URL=redis://localhost:6379/0

# --- LLM (Ollama, swappable model) ---
OLLAMA_HOST=http://localhost:11434
LLM_PRIMARY=gemma3:4b
LLM_TEMPERATURE=0.1
LLM_TIMEOUT_S=120

# --- Embeddings ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- OCR ---
OCR_ENGINE=tesseract
TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe
LAYOUT_ENGINE=none

# --- Confidence thresholds ---
CONFIDENCE_THRESHOLD=0.85
OCR_CONFIDENCE_THRESHOLD=0.70

# --- Upload limits ---
MAX_UPLOAD_MB=50
